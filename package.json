    "format:check": "prettier --check \"public/**/*.{js,html,json}\" --ignore-path .prettierignore"
  },
  "author": "Manuel Lerchner",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}