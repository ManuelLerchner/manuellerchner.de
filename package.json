{
  "name": "manuellerchner-website",
  "version": "1.0.0",
  "description": "Personal Website — static",
  "repository": {
    "type": "git",
    "url": "https://github.com/ManuelLerchner/Manuel-Lerchner-Website.git"
  },
  "scripts": {
    "lint": "eslint public/js",
    "lint:fix": "eslint public/js --fix",
